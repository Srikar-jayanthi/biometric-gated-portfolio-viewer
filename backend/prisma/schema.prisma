generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  holdings  Holding[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Holding {
  id            String   @id @default(cuid())
  ticker        String
  shareCount    Float
  purchasePrice Float
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
